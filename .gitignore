# secrets — NEVER commit (Google API key etc.); set these as Railway variables
.env
.env.local
.env.*.local

# python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# local runtime state — regenerable or ephemeral, not part of the repo
data/*.sqlite
data/*.sqlite-journal
data/_*
data/audio/
data/raw/
web/_*
*.log

# root-level design/authoring scratch copies (the live UI is web/index.html)
/index*.html

# os / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# NOTE: the discovery catalogs (data/sources_catalog.json, arcgis_catalog.json,
# p2c_agencies.json, pulsepoint_agencies.json, southern_agencies.json, type_map.json)
