# Broadcastify Calls API — https://www.broadcastify.com/calls/
BROADCASTIFY_API_KEY=
BROADCASTIFY_USERNAME=
BROADCASTIFY_PASSWORD=

# Anthropic
ANTHROPIC_API_KEY=

# Models: heavy extraction vs. cheap high-volume classification
APB_MODEL_HEAVY=claude-opus-4-8
APB_MODEL_LIGHT=claude-haiku-4-5-20251001

# OpenAI alternative for the type learner (used if OPENAI_API_KEY is set; takes
# precedence over Anthropic). Either provider works — it's a JSON mapping task.
OPENAI_API_KEY=
APB_MODEL_OPENAI=gpt-4o-mini

# Google Programmable Search (source discovery via dorks). Free tier 100 queries/day.
# CX = create at programmablesearchengine.google.com (set "search entire web").
# KEY = enable Custom Search API + make a key at console.cloud.google.com.
GOOGLE_API_KEY=
GOOGLE_CX=

# Postgres + PostGIS
APB_DATABASE_URL=postgresql+psycopg://apb:apb@localhost:5432/apb

# Whisper
APB_WHISPER_MODEL=large-v3
APB_WHISPER_DEVICE=cuda          # or cpu
APB_WHISPER_COMPUTE_TYPE=float16 # or int8 for cpu

# Storage
APB_AUDIO_DIR=./data/audio

# ── Keyless live lanes ───────────────────────────────────────────────────────
# All keyless lanes are ON by default (Bluesky firehose, news RSS, Reddit/Mastodon
# RSS, ADS-B aircraft). Set the matching *_OFF flag to 1 to disable a lane.
# APB_BLUESKY_OFF=1      # disable Bluesky/ATProto firehose
# APB_NEWS_OFF=1         # disable news RSS poller
# APB_SOCIAL_RSS_OFF=1   # disable Reddit/Mastodon RSS poller
# APB_ADSB_OFF=1         # disable ADS-B aircraft lane (heavy: 14 polls/cycle)
# Drop the geo requirement on news/social posts (else only metro-centroid placed):
# APB_NEWS_KEEP_UNPLACED=1
# APB_SOCIAL_RSS_KEEP_UNPLACED=1
# APB_BLUESKY_KEEP_UNPLACED=1

# ── Optional keyed lanes (only register when their key is set) ────────────────
FIRMS_MAP_KEY=          # NASA satellite wildfire detections — firms.modaps.eosdis.nasa.gov/api/map_key
AIRNOW_KEY=             # EPA AirNow AQI — docs.airnowapi.org
OPENAQ_KEY=             # OpenAQ air quality — openaq.org
AISSTREAM_KEY=          # maritime AIS firehose — aisstream.io
ACLED_EMAIL=            # civil-unrest events — myACLED login email (acleddata.com/user/register)
ACLED_PASSWORD=         # myACLED account password (OAuth; legacy key+email API is retired)

# Self-hosted geocoder for the radio/incident pipeline (not needed for the live map).
# APB_NOMINATIM_URL=http://localhost:8080
